      },
      {
        "index": 3,
        "line": "粒粒皆辛苦",
        "scene": "特写。镜头极度推近碗中的白米饭，聚焦在几粒晶莹饱满的米粒上。米粒的特写占据了大部分画面。画面色调从暖黄转为略带庄严的金色，仿佛每粒米都散发着劳动的光泽。画面右侧飘出一个半透明的思维气泡，气泡内是农民弯腰锄地的微小剪影。",
        "shot_type": "特写",
        "image_url": "/static/images/poems/poem_004/frame_3.jpg",
        "duration_ms": 3000
      }
